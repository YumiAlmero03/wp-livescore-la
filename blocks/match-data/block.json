{
	"$schema": "https://schemas.wp.org/trunk/block.json",
	"apiVersion": 3,
	"name": "wp-livescore/match-data",
	"title": "Match Data",
	"category": "livescore",
	"icon": "editor-table",
	"description": "Displays one Match custom field from the current Match.",
	"textdomain": "wp-livescore-la",
	"attributes": {
			"matchId": { "type": "number", "default": 0 },
			"dataField": { "type": "string", "default": "_match_league_name" },
			"icon": { "type": "string", "default": "" },
			"prefix": { "type": "string", "default": "" },
			"suffix": { "type": "string", "default": "" },
			"textTransform": { "type": "string", "default": "" },
			"textAlign": { "type": "string", "default": "" },
			"makeLink": { "type": "boolean", "default": false },
			"emptyMessage": { "type": "string", "default": "" }
		},
	"usesContext": [ "postId", "postType" ],
	"supports": {
		"align": [ "wide", "full" ],
		"anchor": true,
		"color": { "background": true, "text": true },
		"spacing": { "margin": true, "padding": true, "blockGap": true },
		"typography": { "fontSize": true, "lineHeight": true, "textTransform": true }
	},
	"editorScript": "file:./index.js",
	"style": "file:./style.css",
	"editorStyle": "file:./style.css",
	"render": "file:./render.php"
}
