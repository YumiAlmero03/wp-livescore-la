{
	"$schema": "https://schemas.wp.org/trunk/block.json",
	"apiVersion": 3,
	"name": "wp-livescore/related-matches",
	"title": "Related Matches",
	"category": "livescore",
	"icon": "calendar-alt",
	"description": "Displays matches connected to the current League.",
	"textdomain": "wp-livescore-la",
	"attributes": {
		"title": { "type": "string", "default": "Related Matches" },
		"leagueId": { "type": "number", "default": 0 },
		"leagueApiId": { "type": "string", "default": "" },
		"dateFilter": { "type": "string", "default": "all" },
		"customDate": { "type": "string", "default": "" },
		"postsPerPage": { "type": "number", "default": 6 },
		"layoutType": { "type": "string", "default": "grid" },
		"displayStyle": { "type": "string", "default": "list" },
		"showLeague": { "type": "boolean", "default": false },
		"showSeason": { "type": "boolean", "default": true },
		"showVenue": { "type": "boolean", "default": true },
		"showStatus": { "type": "boolean", "default": true },
		"showSportScore": { "type": "boolean", "default": false },
		"emptyMessage": { "type": "string", "default": "No related matches found." }
	},
	"usesContext": [ "postId", "postType" ],
	"supports": {
		"align": [ "wide", "full" ],
		"anchor": true,
		"color": { "background": true, "text": true, "link": true },
		"spacing": { "margin": true, "padding": true, "blockGap": true },
		"typography": { "fontSize": true, "lineHeight": true }
	},
	"editorScript": "file:./index.js",
	"style": "file:./style.css",
	"editorStyle": "file:./style.css",
	"render": "file:./render.php"
}
