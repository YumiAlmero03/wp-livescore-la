{
	"$schema": "https://schemas.wp.org/trunk/block.json",
	"apiVersion": 3,
	"name": "wp-livescore/opponent-team",
	"title": "Opponent Team",
	"category": "livescore",
	"icon": "shield",
	"description": "Displays the team opposite the selected team for the current Match.",
	"textdomain": "wp-livescore-la",
	"attributes": {
		"matchId": { "type": "number", "default": 0 },
		"teamId": { "type": "number", "default": 0 },
		"showImage": { "type": "boolean", "default": true },
		"imageSize": { "type": "number", "default": 3 },
		"imagePosition": { "type": "string", "default": "left" },
		"useShortName": { "type": "boolean", "default": false },
		"makeLink": { "type": "boolean", "default": true },
		"emptyMessage": { "type": "string", "default": "" }
	},
	"usesContext": [ "postId", "postType", "query" ],
	"supports": {
		"align": [ "wide", "full" ],
		"anchor": true,
		"color": { "background": true, "text": true, "link": true },
		"spacing": { "margin": true, "padding": true, "blockGap": true },
		"typography": { "fontSize": true, "lineHeight": true }
	},
	"editorScript": "file:./index.js",
	"style": "file:./style.css",
	"editorStyle": "file:./style.css",
	"render": "file:./render.php"
}
