{
	"$schema": "https://schemas.wp.org/trunk/block.json",
	"apiVersion": 3,
	"name": "wp-livescore/match-status",
	"title": "Match Status",
	"category": "livescore",
	"icon": "clock",
	"description": "Displays a calculated Match status from the Match date and time.",
	"textdomain": "wp-livescore-la",
	"attributes": {
		"matchId": { "type": "number", "default": 0 },
		"prefix": { "type": "string", "default": "" },
		"suffix": { "type": "string", "default": "" },
		"showIcon": { "type": "boolean", "default": false },
		"emptyMessage": { "type": "string", "default": "" }
	},
	"usesContext": [ "postId", "postType" ],
	"supports": {
		"align": [ "wide", "full" ],
		"anchor": true,
		"color": { "background": true, "text": true },
		"spacing": { "margin": true, "padding": true, "blockGap": true },
		"typography": { "fontSize": true, "lineHeight": true, "textTransform": true }
	},
	"editorScript": "file:./index.js",
	"style": "file:./style.css",
	"editorStyle": "file:./style.css",
	"render": "file:./render.php"
}
