{
	"$schema": "https://schemas.wp.org/trunk/block.json",
	"apiVersion": 3,
	"name": "wp-livescore/match-win-graph",
	"title": "Match Win Graph",
	"category": "livescore",
	"icon": "chart-bar",
	"description": "Displays a graph for Home Win %, Draw %, and Away Win %.",
	"textdomain": "wp-livescore-la",
	"attributes": {
		"matchId": { "type": "number", "default": 0 },
		"title": { "type": "string", "default": "Win Probability" },
		"showTitle": { "type": "boolean", "default": true },
		"homeColor": { "type": "string", "default": "" },
		"drawColor": { "type": "string", "default": "" },
		"awayColor": { "type": "string", "default": "" },
		"emptyMessage": { "type": "string", "default": "" }
	},
	"usesContext": [ "postId", "postType" ],
	"supports": {
		"align": [ "wide", "full" ],
		"anchor": true,
		"color": { "background": true, "text": true },
		"spacing": { "margin": true, "padding": true, "blockGap": true },
		"typography": { "fontSize": true, "lineHeight": true }
	},
	"editorScript": "file:./index.js",
	"style": "file:./style.css",
	"editorStyle": "file:./style.css",
	"render": "file:./render.php"
}
