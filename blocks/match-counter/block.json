{
	"$schema": "https://schemas.wp.org/trunk/block.json",
	"apiVersion": 3,
	"name": "wp-livescore/match-counter",
	"title": "Match Counter",
	"category": "livescore",
	"icon": "chart-bar",
	"description": "Displays counts for upcoming, live, and past matches.",
	"textdomain": "wp-livescore-la",
	"attributes": {
		"leagueId": { "type": "number", "default": 0 },
		"showAll": { "type": "boolean", "default": true },
		"showUpcoming": { "type": "boolean", "default": true },
		"showLive": { "type": "boolean", "default": true },
		"showToday": { "type": "boolean", "default": true },
		"showPast": { "type": "boolean", "default": true },
		"showTeams": { "type": "boolean", "default": false },
		"allLabel": { "type": "string", "default": "All" },
		"upcomingLabel": { "type": "string", "default": "Upcoming" },
		"liveLabel": { "type": "string", "default": "Live" },
		"todayLabel": { "type": "string", "default": "Today" },
		"pastLabel": { "type": "string", "default": "Past" },
		"teamsLabel": { "type": "string", "default": "Teams" }
	},
	"usesContext": [ "postId", "postType" ],
	"supports": {
		"align": [ "wide", "full" ],
		"anchor": true,
		"color": { "background": true, "text": true },
		"spacing": { "margin": true, "padding": true, "blockGap": true },
		"typography": { "fontSize": true, "lineHeight": true }
	},
	"editorScript": "file:./index.js",
	"style": "file:./style.css",
	"editorStyle": "file:./style.css",
	"render": "file:./render.php"
}
