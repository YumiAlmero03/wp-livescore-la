{
	"$schema": "https://schemas.wp.org/trunk/block.json",
	"apiVersion": 3,
	"name": "wp-livescore/sports",
	"title": "Sports",
	"category": "livescore",
	"icon": "awards",
	"description": "Displays Sport categories assigned to the current League, Match, Team, or Player.",
	"textdomain": "wp-livescore-la",
	"attributes": {
		"postId": { "type": "number", "default": 0 },
		"showIcon": { "type": "boolean", "default": true },
		"makeLink": { "type": "boolean", "default": false },
		"emptyMessage": { "type": "string", "default": "" }
	},
	"usesContext": [ "postId", "postType" ],
	"supports": {
		"align": [ "wide", "full" ],
		"anchor": true,
		"color": { "background": true, "text": true, "link": true },
		"spacing": { "margin": true, "padding": true, "blockGap": true },
		"typography": { "fontSize": true, "lineHeight": true }
	},
	"editorScript": "file:./index.js",
	"style": "file:./style.css",
	"editorStyle": "file:./style.css",
	"render": "file:./render.php"
}
