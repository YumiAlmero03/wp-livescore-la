{
	"$schema": "https://schemas.wp.org/trunk/block.json",
	"apiVersion": 3,
	"name": "wp-livescore/league-socials",
	"title": "League Socials",
	"category": "livescore",
	"icon": "share",
	"description": "Displays League website and social icons when links exist.",
	"textdomain": "wp-livescore-la",
	"attributes": {
		"leagueId": { "type": "number", "default": 0 },
		"openNewTab": { "type": "boolean", "default": true }
	},
	"usesContext": [ "postId", "postType" ],
	"supports": {
		"align": [ "wide", "full" ],
		"anchor": true,
		"color": { "background": true, "text": true, "link": true },
		"spacing": { "margin": true, "padding": true, "blockGap": true },
		"typography": { "fontSize": true, "lineHeight": true }
	},
	"editorScript": "file:./index.js",
	"style": "file:./style.css",
	"editorStyle": "file:./style.css",
	"render": "file:./render.php"
}
